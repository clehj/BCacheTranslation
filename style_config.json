{
  "window": {
    "title": "BCacheTranslation",
    "min_width": 1000,
    "min_height": 700,
    "margins": [15, 10, 15, 10],
    "spacing": 10
  },
  "fonts": {
    "family": "Microsoft YaHei",
    "sizes": {
      "global": 10,
      "title": 24,
      "button": 13,
      "card_title": 14,
      "card_detail": 11,
      "log": 11,
      "label": 13,
      "checkbox": 12
    }
  },
  "colors": {
    "primary": "#6366f1",
    "success": "#10b981",
    "danger": "#ef4444",
    "warning": "#f59e0b",
    "info": "#8b8ea8",
    "dark": "#1e1e2e",
    "light": "#313244",
    "border": "#45475a",
    "background": "#1e1e2e",
    "card_bg": "#313244",
    "card_hover": "#45475a",
    "text": "#cdd6f4",
    "text_secondary": "#a6adc8",
    "log_bg": "#11111b",
