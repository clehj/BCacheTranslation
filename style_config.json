  },
  "buttons": {
    "select_all": {"text": "✓ 全选", "color": "#10b981"},
    "deselect_all": {"text": "✗ 取消全选", "color": "#f59e0b"},
    "output_dir": {"text": "📁 输出目录", "color": "#6366f1"},
