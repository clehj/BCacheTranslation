    "start": {"text": "▶ 开始处理", "color": "#10b981"},
    "stop": {"text": "⏹ 停止", "color": "#ef4444"},
    "rescan": {"text": "🔄 刷新", "color": "#6366f1"}
  },
  "status_colors": {
    "PENDING": "#8b8ea8",
    "PROCESSING": "#6366f1",
    "SUCCESS": "#10b981",
    "FAILED": "#ef4444",
